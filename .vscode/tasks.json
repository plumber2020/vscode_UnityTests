{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "MAIN",
      "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}\\main.c",
        "${workspaceFolder}\\src\\*.c",
        "-I",
        "${workspaceFolder}",
        "-I",
        "${workspaceFolder}\\include",
        "-o",
        "${workspaceFolder}\\build\\main.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": "build",
      "detail": "Task generated by Debugger."
    },
    {
      "type": "cppbuild",
      "label": "TEST",
      "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${workspaceFolder}\\src\\*.c",
        "${workspaceFolder}\\test\\*.c",
        "${workspaceFolder}\\test\\test_runners\\*.c",
        // Unity ----------------------------------------------------
        "${workspaceFolder}\\UnityTesting\\src\\*.c",
        "${workspaceFolder}\\UnityTesting\\extras\\fixture\\src\\*.c",
        "${workspaceFolder}\\UnityTesting\\extras\\memory\\src\\*.c",
        // Unity ----------------------------------------------------
        "-I", "${workspaceFolder}",
        "-I", "${workspaceFolder}\\include",
        "-I", "${workspaceFolder}\\UnityTesting\\src",
        "-I", "${workspaceFolder}\\UnityTesting\\extras\\fixture\\src",
        "-I", "${workspaceFolder}\\UnityTesting\\extras\\memory\\src",

        "-o",
        "${workspaceFolder}\\build\\test.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger."
    }
  ],
  "version": "2.0.0"
}